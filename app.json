{
  "expo": {
    "name": "Kaly",
    "slug": "kaly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "kaly",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.kaly.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Kaly uses the camera to scan your food and calculate calories",
        "NSPhotoLibraryUsageDescription": "Kaly needs photo access to import food images for analysis",
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "This allows us to provide a better experience and relevant content."
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ],
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeHealthData",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeUserID",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePhotoOrVideo",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataTypeIdentifier": "NSPrivacyCollectedDataTypeHealthAndFitness",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeEmailAddress",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ],
        "NSPrivacyTracking": false
      }
    },
    "android": {
      "package": "app.kaly.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false,
          "healthSharePermission": "Kaly uses Apple Health to sync your nutrition data and show your activity",
          "healthUpdatePermission": "Kaly saves your meals, water intake, and weight to Apple Health"
        }
      ],
      "expo-font",
      "expo-localization",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Kaly uses the camera to scan food and calculate calories"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Kaly needs photo access to import food images"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4CAF50",
          "notificationPermissionText": "Kaly sends water reminders and meal logging prompts to help you stay on track with your nutrition goals."
        }
      ],
      "expo-tracking-transparency",
      [
        "@sentry/react-native/expo",
        {
          "organization": "doclear",
          "project": "kaly"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/67f656ee-fffd-4a8d-93b3-f7268c965730"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "67f656ee-fffd-4a8d-93b3-f7268c965730"
      }
    },
    "owner": "doclear"
  }
}
